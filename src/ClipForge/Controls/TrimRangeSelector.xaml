<UserControl x:Class="ClipForge.Controls.TrimRangeSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="42"
             Focusable="False"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <Style x:Key="TrimRangeThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Focusable" Value="True" />
            <Setter Property="Cursor" Value="SizeWE" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Grid>
                            <Border x:Name="FocusRing"
                                    Margin="-3"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="2"
                                    CornerRadius="7" />
                            <Border x:Name="Handle"
                                    Background="{DynamicResource AccentHoverBrush}"
                                    BorderBrush="White"
                                    BorderThickness="1.5"
                                    CornerRadius="5">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                    <Border Width="1" Height="14" Margin="0,0,3,0"
                                            Background="{DynamicResource PrimaryButtonTextBrush}" />
                                    <Border Width="1" Height="14"
                                            Background="{DynamicResource PrimaryButtonTextBrush}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Handle" Property="Background"
                                        Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="Handle" Property="Background"
                                        Value="{DynamicResource AccentPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="FocusRing" Property="BorderBrush"
                                        Value="{DynamicResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Handle" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="TrackArea"
          MinHeight="42"
          Background="Transparent"
          SizeChanged="TrackArea_SizeChanged"
          MouseLeftButtonDown="TrackArea_MouseLeftButtonDown">
        <Border x:Name="FullTrack"
                Height="7"
                Margin="9,0"
                VerticalAlignment="Center"
                Background="{DynamicResource BorderStrongBrush}"
                CornerRadius="4" />
        <Border x:Name="SelectedTrack"
                Height="7"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Background="{DynamicResource AccentBrush}"
                CornerRadius="4"
                IsHitTestVisible="False" />
        <Canvas x:Name="HandleCanvas" ClipToBounds="False">
            <Thumb x:Name="StartThumb"
                   Style="{StaticResource TrimRangeThumbStyle}"
                   AutomationProperties.Name="Trim start handle"
                   AutomationProperties.HelpText="Use the arrow keys to adjust the beginning of the trimmed clip"
                   DragDelta="StartThumb_DragDelta"
                   DragCompleted="Thumb_DragCompleted"
                   PreviewKeyDown="StartThumb_PreviewKeyDown" />
            <Thumb x:Name="EndThumb"
                   Style="{StaticResource TrimRangeThumbStyle}"
                   AutomationProperties.Name="Trim end handle"
                   AutomationProperties.HelpText="Use the arrow keys to adjust the end of the trimmed clip"
                   DragDelta="EndThumb_DragDelta"
                   DragCompleted="Thumb_DragCompleted"
                   PreviewKeyDown="EndThumb_PreviewKeyDown" />
        </Canvas>
    </Grid>
</UserControl>
