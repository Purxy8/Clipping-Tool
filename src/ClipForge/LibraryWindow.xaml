<Window x:Class="ClipForge.LibraryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClipForge"
        xmlns:controls="clr-namespace:ClipForge.Controls"
        Title="ClipForge — Clip Library"
        Width="1240"
        Height="790"
        MinWidth="980"
        MinHeight="650"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="{DynamicResource WindowBrush}"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <local:ThumbnailPathConverter x:Key="ThumbnailPathConverter" />

        <Style x:Key="LibraryTransportSliderStyle" TargetType="{x:Type Slider}">
            <Setter Property="Height" Value="24" />
            <Setter Property="MinWidth" Value="80" />
            <Setter Property="IsMoveToPointEnabled" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid Background="Transparent">
                            <Border x:Name="SliderFocusRing" Height="13" VerticalAlignment="Center"
                                    BorderBrush="Transparent" BorderThickness="1" CornerRadius="7" />
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" IsTabStop="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                <Border Height="5" Background="{DynamicResource AccentBrush}" CornerRadius="3" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}" IsTabStop="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                <Border Height="5" Background="{DynamicResource BorderStrongBrush}" CornerRadius="3" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="16" Height="16">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Ellipse Fill="{DynamicResource AccentHoverBrush}"
                                                         Stroke="White" StrokeThickness="2" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="SliderFocusRing" Property="BorderBrush"
                                        Value="{DynamicResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PART_Track" Property="Opacity" Value="0.38" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LibraryContextMenuStyle" TargetType="{x:Type ContextMenu}">
            <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="5" />
            <Setter Property="HasDropShadow" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LibraryMenuItemStyle" TargetType="{x:Type MenuItem}">
            <Setter Property="MinWidth" Value="190" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="MenuItemBorder" Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="MenuItemBorder" Property="Background"
                                        Value="{DynamicResource SurfaceHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="MenuItemBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LibraryListItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="ItemBorder"
                                Padding="7"
                                Background="{DynamicResource SurfaceRaisedBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="11">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background"
                                        Value="{DynamicResource SurfaceHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background"
                                        Value="{DynamicResource SurfaceHoverBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush"
                                        Value="{DynamicResource AccentHoverBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush"
                                        Value="{DynamicResource AccentHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource WindowBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="24,20,24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{DynamicResource PageTitleStyle}" Text="Clip library" />
                <TextBlock x:Name="LibraryStatusText" Margin="0,4,0,0"
                           Style="{DynamicResource MutedTextStyle}"
                           Text="Loading your local clips…" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="RefreshButton" MinWidth="104" Margin="0,0,8,0"
                        Content="Refresh" Click="RefreshButton_Click"
                        Style="{DynamicResource QuietButtonStyle}" />
                <Button MinWidth="92" Content="Close" Click="CloseButton_Click"
                        Style="{DynamicResource SecondaryButtonStyle}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="24,0,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="12"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Margin="4,1,4,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Margin="0,0,8,0" VerticalAlignment="Center"
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="Show" />
                            <ComboBox x:Name="LibraryFilterComboBox" Width="142" Height="34" MinHeight="34"
                                      Padding="9,4" VerticalContentAlignment="Center"
                                      SelectionChanged="LibraryFilterComboBox_SelectionChanged"
                                      AutomationProperties.Name="Clip library filter" />
                        </StackPanel>
                        <Border Grid.Column="1" Padding="8,4"
                                Background="{DynamicResource AccentSoftBrush}"
                                CornerRadius="8">
                            <TextBlock x:Name="ClipCountText" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentHoverBrush}" Text="0" />
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1">
                        <ListBox x:Name="ClipList"
                                 Padding="0"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ItemContainerStyle="{StaticResource LibraryListItemStyle}"
                                 ScrollViewer.CanContentScroll="True"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 SelectionChanged="ClipList_SelectionChanged"
                                 AutomationProperties.Name="Clip library">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="82">
                                        <Grid.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                                         Style="{StaticResource LibraryContextMenuStyle}">
                                                <MenuItem Header="Show in File Explorer" Tag="{Binding}"
                                                          Click="ShowInExplorerMenuItem_Click"
                                                          Style="{StaticResource LibraryMenuItemStyle}" />
                                                <MenuItem Header="Delete clip…" Tag="{Binding}"
                                                          Click="DeleteClipMenuItem_Click"
                                                          Style="{StaticResource LibraryMenuItemStyle}" />
                                            </ContextMenu>
                                        </Grid.ContextMenu>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="118" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Background="{DynamicResource WindowBrush}" CornerRadius="8" ClipToBounds="True">
                                            <Grid>
                                                <Border x:Name="ThumbnailPlaceholder"
                                                        Background="{DynamicResource SurfaceRaisedBrush}">
                                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontSize="9" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextMutedBrush}"
                                                               Text="PREVIEW" />
                                                </Border>
                                                <Image Source="{Binding ThumbnailPath, Converter={StaticResource ThumbnailPathConverter}}"
                                                       Stretch="UniformToFill" />
                                                <Border Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        Background="{DynamicResource SurfaceOverlayBrush}"
                                                        BorderBrush="{DynamicResource BorderStrongBrush}"
                                                        BorderThickness="1" CornerRadius="13">
                                                    <TextBlock Margin="2,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontSize="11" Foreground="White" Text="▶" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="10,4,2,2" VerticalAlignment="Center">
                                            <TextBlock FontSize="12" FontWeight="SemiBold"
                                                       Text="{Binding FileName}"
                                                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Margin="0,5,0,0" FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Text="{Binding RecordedAtLocal, StringFormat={}{0:dd MMM yyyy · HH:mm}}" />
                                            <TextBlock Margin="0,2,0,0" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       Text="{Binding FileSizeDisplay}" />
                                            <Border x:Name="TrimmedBadge" Margin="0,5,0,0" Padding="6,2"
                                                    HorizontalAlignment="Left" Visibility="Collapsed"
                                                    Background="{DynamicResource AccentSoftBrush}" CornerRadius="5">
                                                <TextBlock FontSize="9" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentHoverBrush}"
                                                           Text="TRIMMED" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsTrimmed}" Value="True">
                                            <Setter TargetName="TrimmedBadge" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel x:Name="LoadingState" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Width="48" Height="48" Background="{DynamicResource AccentSoftBrush}" CornerRadius="24">
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="20" Foreground="{DynamicResource AccentHoverBrush}" Text="↻" />
                            </Border>
                            <TextBlock Margin="0,12,0,0" HorizontalAlignment="Center"
                                       Style="{DynamicResource MutedTextStyle}" Text="Loading clips…" />
                        </StackPanel>

                        <StackPanel x:Name="EmptyLibraryState" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="Collapsed">
                            <TextBlock HorizontalAlignment="Center" FontSize="30"
                                       Foreground="{DynamicResource TextMutedBrush}" Text="▣" />
                            <TextBlock Margin="0,10,0,4" HorizontalAlignment="Center"
                                       FontWeight="SemiBold" Text="No clips yet" />
                            <TextBlock MaxWidth="220" HorizontalAlignment="Center" TextAlignment="Center"
                                       Style="{DynamicResource MutedTextStyle}"
                                       Text="Saved ClipForge recordings will appear here." />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Padding="14"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Margin="3,1,3,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="SelectedClipNameText" FontSize="15" FontWeight="SemiBold"
                                       Text="Select a clip" TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="SelectedClipDetailsText" Margin="0,4,0,0"
                                       Style="{DynamicResource MutedTextStyle}"
                                       Text="Choose any recording from the library to watch it here." />
                            <TextBlock x:Name="ReplayPlaybackHintText" Margin="0,4,0,0"
                                       Visibility="Collapsed" TextWrapping="Wrap"
                                       FontSize="10" Foreground="{DynamicResource WarningBrush}"
                                       Text="Replay is active: preview starts muted. Unmute only if you want its audio in the rolling buffer." />
                        </StackPanel>
                        <Border Grid.Column="1" Padding="9,5" VerticalAlignment="Center"
                                Background="{DynamicResource AccentSoftBrush}" CornerRadius="8">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Margin="0,0,6,0" VerticalAlignment="Center"
                                         Fill="{DynamicResource AccentBrush}" />
                                <TextBlock FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentHoverBrush}" Text="LOCAL PLAYER" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="1" Background="{DynamicResource WindowBrush}" CornerRadius="12" ClipToBounds="True">
                        <Grid x:Name="LibraryPlayerHost">
                            <Image x:Name="PlayerPosterImage"
                                   Source="{Binding ThumbnailPath, Converter={StaticResource ThumbnailPathConverter}}"
                                   Stretch="Uniform" IsHitTestVisible="False" />
                            <MediaElement x:Name="LibraryPlayer"
                                          LoadedBehavior="Manual"
                                          UnloadedBehavior="Manual"
                                          Stretch="Uniform"
                                          ScrubbingEnabled="True"
                                          Volume="0.8"
                                          Cursor="Hand"
                                          MouseLeftButtonUp="LibraryPlayer_MouseLeftButtonUp"
                                          MediaOpened="LibraryPlayer_MediaOpened"
                                          MediaEnded="LibraryPlayer_MediaEnded"
                                          MediaFailed="LibraryPlayer_MediaFailed"
                                          AutomationProperties.Name="Library clip player"
                                          AutomationProperties.HelpText="Click to play or pause the selected clip" />
                            <Button x:Name="SurfacePlayButton" Width="70" Height="70" Padding="0"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="Collapsed" Content="▶" FontSize="24"
                                    Click="PlayPauseButton_Click"
                                    Style="{DynamicResource PrimaryButtonStyle}"
                                    AutomationProperties.Name="Play selected library clip" />
                            <Grid x:Name="PlayerEmptyState" Background="{DynamicResource WindowBrush}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border Width="68" Height="68"
                                            Background="{DynamicResource AccentSoftBrush}" CornerRadius="34">
                                        <TextBlock Margin="5,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="27" Foreground="{DynamicResource AccentHoverBrush}" Text="▶" />
                                    </Border>
                                    <TextBlock Margin="0,15,0,4" HorizontalAlignment="Center"
                                               FontSize="16" FontWeight="SemiBold" Text="Pick a moment to replay" />
                                    <TextBlock HorizontalAlignment="Center" TextAlignment="Center"
                                               Style="{DynamicResource MutedTextStyle}"
                                               Text="Playback stays inside ClipForge." />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2" Margin="3,10,3,2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="SeekSlider" Minimum="0" Maximum="1" Value="0"
                                    IsEnabled="False" SmallChange="1" LargeChange="10"
                                    ValueChanged="SeekSlider_ValueChanged"
                                    PreviewMouseLeftButtonDown="SeekSlider_PreviewMouseLeftButtonDown"
                                    PreviewMouseLeftButtonUp="SeekSlider_PreviewMouseLeftButtonUp"
                                    PreviewKeyDown="SeekSlider_PreviewKeyDown"
                                    Style="{StaticResource LibraryTransportSliderStyle}"
                                    AutomationProperties.Name="Library clip position" />
                            <TextBlock x:Name="TimeText" Grid.Column="1" MinWidth="112" Margin="12,0,0,0"
                                       VerticalAlignment="Center" TextAlignment="Right"
                                       FontFamily="Consolas" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Text="0:00 / 0:00" />
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,5,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="112" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="PlayPauseButton" Width="48" Height="44" Padding="0"
                                    Content="▶" IsEnabled="False" Click="PlayPauseButton_Click"
                                    Style="{DynamicResource PrimaryButtonStyle}" ToolTip="Play clip" />
                            <Button x:Name="RestartButton" Grid.Column="1" Width="42" Height="42" Margin="6,0,0,0"
                                    Padding="0" Content="↻" IsEnabled="False" Click="RestartButton_Click"
                                    Style="{DynamicResource QuietButtonStyle}" ToolTip="Replay from the beginning" />
                            <Button x:Name="BackTenButton" Grid.Column="2" Width="52" Height="42" Margin="6,0,0,0"
                                    Padding="0" Content="−10" IsEnabled="False" Click="BackTenButton_Click"
                                    Style="{DynamicResource QuietButtonStyle}" ToolTip="Back 10 seconds" />
                            <Button x:Name="ForwardTenButton" Grid.Column="3" Width="52" Height="42" Margin="6,0,0,0"
                                    Padding="0" Content="+10" IsEnabled="False" Click="ForwardTenButton_Click"
                                    Style="{DynamicResource QuietButtonStyle}" ToolTip="Forward 10 seconds" />
                            <Button x:Name="BeginTrimButton" Grid.Column="4" Height="42" MinWidth="88" Margin="12,0,0,0"
                                    Padding="14,7" HorizontalAlignment="Left" Content="Trim clip"
                                    IsEnabled="False" Click="BeginTrimButton_Click"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    AutomationProperties.Name="Trim selected library clip" />
                            <Button x:Name="MuteButton" Grid.Column="5" Width="46" Height="42" Margin="8,0,4,0"
                                    Padding="0" Content="🔊" IsEnabled="False" Click="MuteButton_Click"
                                    Style="{DynamicResource QuietButtonStyle}" ToolTip="Mute clip audio" />
                            <Slider x:Name="VolumeSlider" Grid.Column="6" Margin="4,0,0,0"
                                    Minimum="0" Maximum="100" Value="80" SmallChange="5" LargeChange="10"
                                    IsEnabled="False" ValueChanged="VolumeSlider_ValueChanged"
                                    Style="{StaticResource LibraryTransportSliderStyle}"
                                    AutomationProperties.Name="Library clip volume" />
                        </Grid>

                        <Border x:Name="TrimEditorPanel" Grid.Row="2" Margin="0,12,0,0" Padding="14"
                                Visibility="Collapsed"
                                Background="{DynamicResource SurfaceRaisedBrush}"
                                BorderBrush="{DynamicResource AccentBorderBrush}"
                                BorderThickness="1" CornerRadius="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontSize="14" FontWeight="SemiBold" Text="Trim selected moment" />
                                        <TextBlock Margin="0,3,0,0" Style="{DynamicResource MutedTextStyle}"
                                                   Text="Drag both handles to choose the part you want to keep." />
                                    </StackPanel>
                                    <Button x:Name="CancelTrimModeButton" Grid.Column="1" Width="34" Height="32" Padding="0"
                                            Content="&#x2715;" Click="CancelTrimModeButton_Click"
                                            Style="{DynamicResource QuietButtonStyle}" ToolTip="Close trim editor"
                                            AutomationProperties.Name="Close trim editor" />
                                </Grid>

                                <controls:TrimRangeSelector x:Name="TrimRangeSelector" Grid.Row="1" Margin="0,11,0,2"
                                                            Minimum="0" Maximum="1" LowerValue="0" UpperValue="1"
                                                            MinimumSpan="0.25"
                                                            RangeChanged="TrimRangeSelector_RangeChanged"
                                                            RangeChangeCompleted="TrimRangeSelector_RangeChangeCompleted"
                                                            AutomationProperties.Name="Trim range" />

                                <Grid Grid.Row="2" Margin="2,1,2,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontSize="9" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextMutedBrush}" Text="START" />
                                        <TextBlock x:Name="TrimStartText" Margin="0,2,0,0" FontFamily="Consolas"
                                                   FontSize="12" Text="0:00.0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock HorizontalAlignment="Center" FontSize="9" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextMutedBrush}" Text="LENGTH" />
                                        <TextBlock x:Name="TrimLengthText" Margin="0,2,0,0" HorizontalAlignment="Center"
                                                   FontFamily="Consolas" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentHoverBrush}" Text="0:00.0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                        <TextBlock HorizontalAlignment="Right" FontSize="9" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextMutedBrush}" Text="END" />
                                        <TextBlock x:Name="TrimEndText" Margin="0,2,0,0" HorizontalAlignment="Right"
                                                   FontFamily="Consolas" FontSize="12" Text="0:00.0" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock x:Name="TrimContentionText" Grid.Row="3" Margin="0,9,0,0"
                                           Visibility="Collapsed" TextWrapping="Wrap"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           Text="Replay-safe export is active: one software thread, real-time pacing, and Idle priority." />

                                <Grid Grid.Row="4" Margin="0,10,0,0">
                                    <StackPanel x:Name="TrimActionsPanel" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button x:Name="PreviewTrimButton" MinWidth="128" Margin="0,0,8,0"
                                                Content="Preview selection" Click="PreviewTrimButton_Click"
                                                Style="{DynamicResource QuietButtonStyle}" />
                                        <Button x:Name="SaveTrimButton" MinWidth="158"
                                                Content="Save trimmed copy" Click="SaveTrimButton_Click"
                                                Style="{DynamicResource PrimaryButtonStyle}" />
                                    </StackPanel>
                                    <Grid x:Name="TrimProgressPanel" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock FontSize="11" FontWeight="SemiBold" Text="Creating trimmed copy…" />
                                            <ProgressBar Height="5" Margin="0,6,12,0" IsIndeterminate="True" />
                                        </StackPanel>
                                        <Button x:Name="CancelTrimOperationButton" Grid.Column="1" MinWidth="82" Content="Cancel"
                                                Click="CancelTrimOperationButton_Click"
                                                Style="{DynamicResource QuietButtonStyle}" />
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
