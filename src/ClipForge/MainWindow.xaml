<Window x:Class="ClipForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClipForge"
        mc:Ignorable="d"
        Title="ClipForge — Instant Replay"
        Width="1380"
        Height="880"
        MinWidth="1080"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="{DynamicResource WindowBrush}"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <local:ThumbnailPathConverter x:Key="ThumbnailPathConverter" />

        <Style x:Key="AnimatedQuietButtonStyle" TargetType="{x:Type Button}"
               BasedOn="{StaticResource QuietButtonStyle}" />

        <Style x:Key="AnimatedPrimaryButtonStyle" TargetType="{x:Type Button}"
               BasedOn="{StaticResource PrimaryButtonStyle}" />

        <Style x:Key="LibraryLaunchButtonStyle" TargetType="{x:Type Button}"
               BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinWidth" Value="112" />
            <Setter Property="Height" Value="36" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="15,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="AppearanceSwatchButtonStyle" TargetType="{x:Type Button}"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,7,0" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
            <Setter Property="AutomationProperties.HelpText" Value="Apply this appearance color" />
        </Style>

        <Style x:Key="TransportSliderStyle" TargetType="{x:Type Slider}">
            <Setter Property="Height" Value="24" />
            <Setter Property="MinWidth" Value="80" />
            <Setter Property="IsMoveToPointEnabled" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid Background="Transparent">
                            <Border x:Name="SliderFocusRing" Height="13" VerticalAlignment="Center"
                                    BorderBrush="Transparent" BorderThickness="1" CornerRadius="7" />
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" IsTabStop="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                <Border Height="5" Background="{StaticResource AccentBrush}" CornerRadius="3" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}" IsTabStop="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                <Border Height="5" Background="{StaticResource BorderStrongBrush}" CornerRadius="3" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="16" Height="16">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Ellipse Fill="{StaticResource AccentHoverBrush}"
                                                         Stroke="#D8FFFFFF" StrokeThickness="2" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="SliderFocusRing" Property="BorderBrush"
                                        Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PART_Track" Property="Opacity" Value="0.38" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkContextMenuStyle" TargetType="{x:Type ContextMenu}">
            <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="5" />
            <Setter Property="HasDropShadow" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkMenuItemStyle" TargetType="{x:Type MenuItem}">
            <Setter Property="MinWidth" Value="190" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="MenuItemBorder" Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="MenuItemBorder" Property="Background"
                                        Value="{StaticResource SurfaceHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="MenuItemBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootLayout" Background="{DynamicResource WindowBrush}">

        <Grid.RowDefinitions>
            <RowDefinition Height="76" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid x:Name="AppHeader" Grid.Row="0" Margin="24,14,24,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <Border x:Name="BrandMark" Width="46" Height="46" Margin="0,0,13,0"
                        Background="{StaticResource AccentGradientBrush}" CornerRadius="14">
                    <Path Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"
                          Data="M 4,2 L 16,2 C 17.1,2 18,2.9 18,4 L 18,9 L 15,9 L 15,5 L 5,5 L 5,15 L 10,15 L 10,18 L 4,18 C 2.9,18 2,17.1 2,16 L 2,4 C 2,2.9 2.9,2 4,2 Z M 12,9 L 19,13.5 L 12,18 Z"
                          Fill="White" Stretch="Uniform" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource PageTitleStyle}" Text="ClipForge" />
                    <TextBlock Style="{StaticResource MutedTextStyle}" Text="Capture it now. Keep the moment." />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Margin="0,0,10,0" Padding="12,7" Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="18">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StatusDot" Width="8" Height="8" Margin="0,0,8,0"
                                 VerticalAlignment="Center" Fill="{StaticResource TextMutedBrush}" />
                        <TextBlock x:Name="StatusText" VerticalAlignment="Center" FontSize="12"
                                   FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="Replay off" />
                    </StackPanel>
                </Border>
                <Button Width="42" Height="42" Padding="0" Content="—" Click="HideToTrayButton_Click"
                        Style="{StaticResource QuietButtonStyle}" ToolTip="Hide ClipForge to the system tray" />
            </StackPanel>
        </Grid>

        <!-- Non-blocking errors -->
        <Border x:Name="ErrorBanner" Grid.Row="1" Margin="24,0,24,12" Padding="14,11"
                Background="{StaticResource ErrorSoftBrush}" BorderBrush="{StaticResource ErrorBrush}"
                BorderThickness="1" CornerRadius="11" Visibility="Collapsed"
                AutomationProperties.LiveSetting="Assertive">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Width="27" Height="27" Margin="0,0,10,0" Background="{StaticResource ErrorBrush}" CornerRadius="14">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="White" Text="!" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock FontWeight="SemiBold" Text="ClipForge needs your attention" />
                    <TextBlock x:Name="ErrorText" Margin="0,1,0,0" Style="{StaticResource MutedTextStyle}"
                               Text="Something went wrong." />
                </StackPanel>
                <Button Grid.Column="2" Width="34" Height="34" Padding="0" Content="×"
                        Click="DismissErrorButton_Click" Style="{StaticResource QuietButtonStyle}" />
            </Grid>
        </Border>

        <!-- Workspace -->
        <Grid Grid.Row="2" Margin="24,0,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="370" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Settings sidebar -->
            <Border x:Name="CaptureSidebar" Grid.Column="0" Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="20,18,20,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Capture settings" />
                            <TextBlock Margin="0,2,0,0" Style="{StaticResource MutedTextStyle}"
                                       Text="Changes are saved automatically." />
                        </StackPanel>
                        <Border Grid.Column="1" Padding="8,4" VerticalAlignment="Center"
                                Background="{StaticResource AccentSoftBrush}" CornerRadius="7">
                                            <TextBlock x:Name="SidebarVersionText" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentHoverBrush}" Text="V1.3" />
                        </Border>
                    </Grid>

                    <ScrollViewer Grid.Row="1" Padding="20,0,20,20" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled" PanningMode="VerticalOnly">
                        <StackPanel>
                            <!-- Engine setup -->
                            <Border x:Name="InstallEnginePanel" Margin="0,0,0,14" Padding="14"
                                    Background="{StaticResource WarningSoftBrush}" BorderBrush="#6BF4B85B"
                                    BorderThickness="1" CornerRadius="11" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="Capture engine required" />
                                    <TextBlock Margin="0,3,0,8" Style="{StaticResource MutedTextStyle}"
                                               Text="Install the verified FFmpeg engine once." />
                                    <ProgressBar x:Name="InstallProgressBar" Maximum="100" Value="0" />
                                    <TextBlock x:Name="InstallStatusText" Margin="0,5,0,8" Style="{StaticResource MutedTextStyle}" Text="Ready to install" />
                                    <Button x:Name="InstallEngineButton" Content="Install engine"
                                            Click="InstallEngineButton_Click" Style="{StaticResource SecondaryButtonStyle}" />
                                </StackPanel>
                            </Border>

                            <!-- Video -->
                            <Border Margin="0,0,0,12" Style="{StaticResource SidebarSectionStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource EyebrowStyle}" Text="REPLAY &amp; VIDEO" />
                                    <TextBlock Margin="0,10,0,6" Style="{StaticResource FieldLabelStyle}" Text="DISPLAY" />
                                    <ComboBox x:Name="DisplayComboBox" SelectionChanged="DisplayComboBox_SelectionChanged" />

                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="112" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="REPLAY LENGTH" />
                                            <ComboBox x:Name="ReplayLengthComboBox" SelectionChanged="ReplayLengthComboBox_SelectionChanged" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="FPS" />
                                            <ComboBox x:Name="FpsComboBox" SelectionChanged="FpsComboBox_SelectionChanged" />
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Margin="0,12,0,6" Style="{StaticResource FieldLabelStyle}" Text="RESOLUTION" />
                                    <ComboBox x:Name="ResolutionComboBox" SelectionChanged="ResolutionComboBox_SelectionChanged" />

                                    <Border Margin="0,12,0,0" Padding="10,8" Background="{StaticResource SurfaceTranslucentBrush}" CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock x:Name="EncoderStatusText" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource SuccessBrush}" Text="Performance mode: Auto" />
                                            <TextBlock Margin="0,2,0,0" Style="{StaticResource MutedTextStyle}"
                                                       Text="ClipForge tests the GPU and chooses the lowest-impact available encoder." />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Audio -->
                            <Border Margin="0,0,0,12" Style="{StaticResource SidebarSectionStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource EyebrowStyle}" Text="AUDIO" />
                                    <CheckBox x:Name="SystemAudioCheckBox" Margin="0,11,0,8"
                                              Content="Include desktop audio" IsChecked="True"
                                              Checked="SystemAudioCheckBox_Checked" Unchecked="SystemAudioCheckBox_Unchecked"
                                              Style="{StaticResource ToggleCheckBoxStyle}" />
                                    <ComboBox x:Name="OutputDeviceComboBox" SelectionChanged="OutputDeviceComboBox_SelectionChanged" />
                                    <Separator Margin="0,13" Background="{StaticResource BorderBrush}" />
                                    <CheckBox x:Name="MicrophoneCheckBox" Margin="0,0,0,8"
                                              Content="Include microphone" IsChecked="False"
                                              Checked="MicrophoneCheckBox_Checked" Unchecked="MicrophoneCheckBox_Unchecked"
                                              Style="{StaticResource ToggleCheckBoxStyle}" />
                                    <ComboBox x:Name="MicrophoneComboBox" SelectionChanged="MicrophoneComboBox_SelectionChanged" />
                                </StackPanel>
                            </Border>

                            <!-- Shortcuts -->
                            <Border Margin="0,0,0,12" Style="{StaticResource SidebarSectionStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource EyebrowStyle}" Text="SHORTCUTS &amp; OVERLAY" />
                                    <TextBlock Margin="0,9,0,5" Style="{StaticResource FieldLabelStyle}" Text="SAVE CLIP" />
                                    <Button x:Name="SaveHotkeyButton" Click="SaveHotkeyButton_Click"
                                            Style="{StaticResource HotkeyButtonStyle}" HorizontalContentAlignment="Stretch">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="HotkeyText" FontFamily="Consolas" Text="Ctrl + Shift + F10" />
                                            <TextBlock Grid.Column="1" Foreground="{StaticResource TextMutedBrush}" Text="Change" />
                                        </Grid>
                                    </Button>

                                    <TextBlock Margin="0,11,0,5" Style="{StaticResource FieldLabelStyle}" Text="TOGGLE OVERLAY" />
                                    <Button x:Name="OverlayHotkeyButton" Click="OverlayHotkeyButton_Click"
                                            Style="{StaticResource HotkeyButtonStyle}" HorizontalContentAlignment="Stretch">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="OverlayHotkeyText" FontFamily="Consolas" Text="Ctrl + Shift + F9" />
                                            <TextBlock Grid.Column="1" Foreground="{StaticResource TextMutedBrush}" Text="Change" />
                                        </Grid>
                                    </Button>
                                    <TextBlock x:Name="HotkeyCaptureHint" Margin="0,7,0,0" Style="{StaticResource MutedTextStyle}"
                                               Text="Select a shortcut, then press your new key combination." Visibility="Collapsed" />
                                    <TextBlock Margin="0,8,0,0" Style="{StaticResource MutedTextStyle}"
                                               Text="Closing the window hides ClipForge to the tray. Recording and shortcuts continue in the background." />
                                </StackPanel>
                            </Border>

                            <!-- Startup -->
                            <Border Margin="0,0,0,12" Style="{StaticResource SidebarSectionStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource EyebrowStyle}" Text="STARTUP" />
                                    <CheckBox x:Name="StartReplayWithWindowsCheckBox" Margin="0,10,0,0"
                                              Click="StartReplayWithWindowsCheckBox_Click"
                                              Style="{StaticResource ToggleCheckBoxStyle}"
                                              AutomationProperties.Name="Start ClipForge and replay with Windows"
                                              AutomationProperties.HelpText="Starts ClipForge hidden in the notification area and begins the replay buffer after Windows sign-in.">
                                        <TextBlock Text="Start ClipForge and replay with Windows"
                                                   TextWrapping="Wrap" />
                                    </CheckBox>
                                    <TextBlock x:Name="StartupHintText" Margin="0,7,0,0"
                                               Style="{StaticResource MutedTextStyle}"
                                               Text="ClipForge starts hidden in the tray and uses your saved capture settings."
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <!-- Appearance -->
                            <Border Margin="0,0,0,12" Style="{StaticResource SidebarSectionStyle}">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource EyebrowStyle}" Text="APPEARANCE" />
                                        <Border Grid.Column="1" Padding="7,3" Background="{StaticResource AccentSoftBrush}"
                                                CornerRadius="6">
                                            <TextBlock x:Name="AppearanceColorValueText" FontFamily="Consolas" FontSize="10"
                                                       Foreground="{StaticResource AccentHoverBrush}" Text="#0B0D12" />
                                        </Border>
                                    </Grid>
                                    <TextBlock Margin="0,8,0,5" Style="{StaticResource FieldLabelStyle}"
                                               Text="COLOR TARGET" />
                                    <ComboBox x:Name="AppearanceTargetComboBox"
                                              SelectionChanged="AppearanceTargetComboBox_SelectionChanged"
                                              AutomationProperties.Name="Appearance color target" />
                                    <TextBlock x:Name="AppearanceHintText" Margin="0,8,0,8"
                                               Style="{StaticResource MutedTextStyle}"
                                               Text="Choose which part of ClipForge you want to recolor." />
                                    <StackPanel x:Name="AppearanceSwatchesPanel" Orientation="Horizontal">
                                        <Button Background="#0B0D12" Click="AppearanceSwatchButton_Click"
                                                Style="{StaticResource AppearanceSwatchButtonStyle}" />
                                        <Button Background="#0D1422" Click="AppearanceSwatchButton_Click"
                                                Style="{StaticResource AppearanceSwatchButtonStyle}" />
                                        <Button Background="#161321" Click="AppearanceSwatchButton_Click"
                                                Style="{StaticResource AppearanceSwatchButtonStyle}" />
                                        <Button Background="#0D1A19" Click="AppearanceSwatchButton_Click"
                                                Style="{StaticResource AppearanceSwatchButtonStyle}" />
                                        <Button Background="#17191F" Click="AppearanceSwatchButton_Click"
                                                Style="{StaticResource AppearanceSwatchButtonStyle}" />
                                    </StackPanel>
                                    <Grid Margin="0,9,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="Custom color" Click="CustomAppearanceColorButton_Click"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                AutomationProperties.Name="Choose a custom appearance color" />
                                        <Button Grid.Column="2" Content="Reset" Click="ResetAppearanceColorButton_Click"
                                                Style="{StaticResource QuietButtonStyle}"
                                                AutomationProperties.Name="Reset selected appearance color" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Feedback -->
                            <Border Margin="0,0,0,12" Style="{StaticResource SidebarSectionStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource EyebrowStyle}" Text="FEEDBACK" />
                                    <CheckBox x:Name="ClipSavedSoundCheckBox" Margin="0,10,0,0"
                                              Content="Play a sound when a clip is saved" IsChecked="True"
                                              Click="ClipSavedSoundCheckBox_Click"
                                              Style="{StaticResource ToggleCheckBoxStyle}" />
                                    <TextBlock Margin="0,7,0,0" Style="{StaticResource MutedTextStyle}"
                                               Text="A clear, low-key confirmation plays only after the MP4 is safely saved."
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <!-- Storage -->
                            <Border Margin="0,0,0,12" Style="{StaticResource SidebarSectionStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource EyebrowStyle}" Text="SAVE LOCATION" />
                                    <TextBlock x:Name="StorageText" Margin="0,7,0,8" Style="{StaticResource MutedTextStyle}" Text="Calculating storage…" />
                                    <TextBox x:Name="SavePathTextBox" IsReadOnly="True" />
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="BrowseButton" Grid.Column="0" Content="Browse" Click="BrowseButton_Click"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                        <Button x:Name="OpenFolderButton" Grid.Column="2" Content="Open folder" Click="OpenFolderButton_Click"
                                                Style="{StaticResource QuietButtonStyle}" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Updates -->
                            <Border x:Name="UpdatePanel" Style="{StaticResource SidebarSectionStyle}">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource EyebrowStyle}" Text="APP UPDATES" />
                                        <TextBlock x:Name="VersionText" Grid.Column="1" FontFamily="Consolas" FontSize="11"
                                                   Foreground="{StaticResource AccentHoverBrush}" Text="v1.2.0" />
                                    </Grid>
                                    <TextBlock x:Name="UpdateStatusText" Margin="0,8,0,8" Style="{StaticResource MutedTextStyle}"
                                               Text="Update status unavailable." />
                                    <ProgressBar x:Name="UpdateProgressBar" Margin="0,0,0,8" Maximum="100" Visibility="Collapsed" />
                                    <Button x:Name="UpdateActionButton" Content="Check for updates" Click="UpdateActionButton_Click"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <CheckBox x:Name="AutoUpdateCheckBox" Margin="0,9,0,0" Content="Check automatically"
                                              Click="AutoUpdateCheckBox_Click" IsChecked="False" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Main content -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="214" />
                </Grid.RowDefinitions>

                <!-- Replay controls -->
                <Border x:Name="ReplayHeroCard" Grid.Row="0" Padding="18"
                        Style="{StaticResource HeroCardStyle}" ClipToBounds="True">
                    <Grid>
                        <Ellipse Width="260" Height="260" Margin="0,-190,-100,0" HorizontalAlignment="Right"
                                 VerticalAlignment="Top" Fill="{StaticResource AccentBrush}" Opacity="0.1" IsHitTestVisible="False" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource EyebrowStyle}" Text="INSTANT REPLAY" />
                                <TextBlock Margin="0,4,0,2" FontSize="20" FontWeight="SemiBold" Text="Ready for the moment?" />
                                <TextBlock x:Name="AvailableText" Style="{StaticResource MutedTextStyle}" Text="No replay buffered" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="BufferToggleButton" MinWidth="120" Margin="0,0,8,0" Content="Start replay"
                                        Click="BufferToggleButton_Click" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button x:Name="SaveClipButton" MinWidth="172" Content="Save last clip" IsEnabled="False"
                                        Click="SaveClipButton_Click" Style="{StaticResource AnimatedPrimaryButtonStyle}" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Player -->
                <Border x:Name="PlayerCard" Grid.Row="2" Padding="0"
                        Style="{StaticResource CardStyle}" ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="64" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="92" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="18,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Latest clip" />
                                <TextBlock x:Name="LatestClipNameText" Margin="0,2,0,0" Style="{StaticResource MutedTextStyle}"
                                           Text="Your newest saved clip will appear here." TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Margin="0,0,8,0" Padding="9,5" Background="{StaticResource SuccessSoftBrush}"
                                        CornerRadius="8">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="6" Height="6" Margin="0,0,6,0" VerticalAlignment="Center"
                                                 Fill="{StaticResource SuccessBrush}" />
                                        <TextBlock FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{StaticResource SuccessBrush}" Text="LOCAL PLAYER" />
                                    </StackPanel>
                                </Border>
                                <Button x:Name="RefreshLibraryButton" Width="40" Height="40" Margin="0,0,6,0" Padding="0"
                                        Content="↻" Click="RefreshLibraryButton_Click" Style="{StaticResource QuietButtonStyle}"
                                        ToolTip="Refresh clips" />
                                <Button x:Name="TrimCurrentClipButton" Height="40" Margin="0,0,6,0" Padding="13,7"
                                        Content="Trim" Click="TrimCurrentClipButton_Click" IsEnabled="False"
                                        Style="{StaticResource QuietButtonStyle}"
                                        ToolTip="Trim this clip in the library"
                                        AutomationProperties.Name="Trim latest clip" />
                                <Button x:Name="OpenCurrentClipButton" Height="40" Content="Open file"
                                        Click="OpenCurrentClipButton_Click" IsEnabled="False" Style="{StaticResource QuietButtonStyle}" />
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="1" Margin="14,0" Background="#05060A" CornerRadius="12" ClipToBounds="True">
                            <Grid x:Name="ClipPlayerHost">
                                <Image x:Name="ClipPlayerPosterImage"
                                       Source="{Binding ThumbnailPath, Converter={StaticResource ThumbnailPathConverter}}"
                                       Stretch="Uniform" IsHitTestVisible="False" />
                                <MediaElement x:Name="ClipPlayer" LoadedBehavior="Manual" UnloadedBehavior="Manual"
                                              Stretch="Uniform" ScrubbingEnabled="True" Volume="0.8"
                                              Cursor="Hand" MouseLeftButtonUp="ClipPlayer_MouseLeftButtonUp"
                                              AutomationProperties.Name="Clip preview player"
                                              AutomationProperties.HelpText="Click to play or pause the selected clip"
                                              MediaOpened="ClipPlayer_MediaOpened" MediaEnded="ClipPlayer_MediaEnded"
                                              MediaFailed="ClipPlayer_MediaFailed" />
                                <Button x:Name="PlayerSurfacePlayButton" Width="70" Height="70" Padding="0"
                                        HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"
                                        Content="&#x25B6;" FontSize="24" Click="PlayPauseButton_Click"
                                        Style="{StaticResource AnimatedPrimaryButtonStyle}"
                                        AutomationProperties.Name="Play selected clip" />
                                <Grid x:Name="PlayerEmptyState" Background="#D9070910">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border Width="62" Height="62" Background="{StaticResource AccentSoftBrush}" CornerRadius="31">
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,0,0,0"
                                                       FontSize="25" Foreground="{StaticResource AccentHoverBrush}" Text="▶" />
                                        </Border>
                                        <TextBlock Margin="0,14,0,4" HorizontalAlignment="Center" FontSize="16"
                                                   FontWeight="SemiBold" Text="Your clips live here" />
                                        <TextBlock MaxWidth="360" HorizontalAlignment="Center" TextAlignment="Center"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Text="Start replay, save a moment, and play it immediately without leaving ClipForge." />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2" Margin="16,5,16,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="PlayerSeekSlider" Minimum="0" Maximum="1" Value="0"
                                        IsEnabled="False" SmallChange="1" LargeChange="10"
                                        ValueChanged="PlayerSeekSlider_ValueChanged"
                                        PreviewMouseLeftButtonDown="PlayerSeekSlider_PreviewMouseLeftButtonDown"
                                        PreviewMouseLeftButtonUp="PlayerSeekSlider_PreviewMouseLeftButtonUp"
                                        PreviewKeyDown="PlayerSeekSlider_PreviewKeyDown"
                                        Style="{StaticResource TransportSliderStyle}"
                                        AutomationProperties.Name="Clip position"
                                        AutomationProperties.HelpText="Seek through the selected clip" />
                                <TextBlock x:Name="PlayerTimeText" Grid.Column="1" MinWidth="108" Margin="12,0,0,0"
                                           VerticalAlignment="Center" TextAlignment="Right" FontFamily="Consolas" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" Text="0:00 / 0:00" />
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="112" />
                                </Grid.ColumnDefinitions>
                                <Button x:Name="PlayPauseButton" Width="48" Height="44" Padding="0" Content="&#x25B6;"
                                        Click="PlayPauseButton_Click" IsEnabled="False"
                                        Style="{StaticResource AnimatedPrimaryButtonStyle}" ToolTip="Play clip"
                                        AutomationProperties.Name="Play selected clip" />
                                <Button x:Name="RestartClipButton" Grid.Column="1" Width="42" Height="42" Margin="6,0,0,0"
                                        Padding="0" Content="&#x21BA;" Click="RestartClipButton_Click" IsEnabled="False"
                                        Style="{StaticResource AnimatedQuietButtonStyle}" ToolTip="Replay from the beginning"
                                        AutomationProperties.Name="Replay clip from the beginning" />
                                <Button x:Name="BackTenSecondsButton" Grid.Column="2" Width="52" Height="42" Margin="6,0,0,0"
                                        Padding="0" Content="&#x2212;10" Click="BackTenSecondsButton_Click" IsEnabled="False"
                                        Style="{StaticResource AnimatedQuietButtonStyle}" ToolTip="Back 10 seconds"
                                        AutomationProperties.Name="Move back 10 seconds" />
                                <Button x:Name="ForwardTenSecondsButton" Grid.Column="3" Width="52" Height="42" Margin="6,0,0,0"
                                        Padding="0" Content="+10" Click="ForwardTenSecondsButton_Click" IsEnabled="False"
                                        Style="{StaticResource AnimatedQuietButtonStyle}" ToolTip="Forward 10 seconds"
                                        AutomationProperties.Name="Move forward 10 seconds" />
                                <Button x:Name="MutePlayerButton" Grid.Column="5" Width="46" Height="42" Margin="8,0,4,0"
                                        Padding="0" Content="&#x1F50A;" Click="MutePlayerButton_Click" IsEnabled="False"
                                        Style="{StaticResource AnimatedQuietButtonStyle}" ToolTip="Mute clip audio"
                                        AutomationProperties.Name="Mute clip audio" />
                                <Slider x:Name="PlayerVolumeSlider" Grid.Column="6" Margin="4,0,0,0"
                                        Minimum="0" Maximum="100" Value="80" SmallChange="5" LargeChange="10"
                                        IsEnabled="False"
                                        ValueChanged="PlayerVolumeSlider_ValueChanged"
                                        Style="{StaticResource TransportSliderStyle}"
                                        AutomationProperties.Name="Clip volume"
                                        AutomationProperties.HelpText="Adjust clip playback volume" />
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Recent gallery -->
                <Border x:Name="RecentClipsCard" Grid.Row="4" Padding="16" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Margin="2,0,2,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="15" FontWeight="SemiBold" Text="Recent clips" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="OpenLibraryButton" Margin="0,0,10,0"
                                        Content="Open Library" Click="OpenLibraryButton_Click"
                                        Style="{StaticResource LibraryLaunchButtonStyle}"
                                        ToolTip="Browse all saved clips"
                                        AutomationProperties.Name="Open full clip library"
                                        AutomationProperties.HelpText="Browse and play all saved clips" />
                                <TextBlock Margin="0,0,7,0" VerticalAlignment="Center"
                                           Style="{StaticResource MutedTextStyle}" Text="Latest" />
                                <ComboBox x:Name="RecentClipCountComboBox" Width="68" Height="30" MinHeight="30"
                                          Padding="9,3" VerticalContentAlignment="Center"
                                          SelectionChanged="RecentClipCountComboBox_SelectionChanged"
                                          AutomationProperties.Name="Number of recent clips" />
                            </StackPanel>
                        </Grid>
                        <ScrollViewer x:Name="RecentClipsScrollViewer" Grid.Row="1"
                                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                      PanningMode="HorizontalOnly" SizeChanged="RecentClipsScrollViewer_SizeChanged">
                        <ItemsControl x:Name="RecentClipsItemsControl" Tag="260">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="{Binding RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}, Path=Tag}"
                                            Height="118" Margin="3" Padding="0" Tag="{Binding}"
                                            Click="RecentClipButton_Click"
                                            Style="{StaticResource GalleryCardButtonStyle}" ToolTip="{Binding FullPath}">
                                        <Button.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}"
                                                         Style="{StaticResource DarkContextMenuStyle}">
                                                <MenuItem Header="Show in File Explorer" Tag="{Binding}"
                                                          Click="ShowRecentClipInExplorerMenuItem_Click"
                                                          Style="{StaticResource DarkMenuItemStyle}" />
                                                <MenuItem Header="Delete clip..." Tag="{Binding}"
                                                          Click="DeleteRecentClipMenuItem_Click"
                                                          Style="{StaticResource DarkMenuItemStyle}" />
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <Grid>
                                            <Border x:Name="ThumbnailPlaceholder"
                                                    Background="{StaticResource SurfaceRaisedBrush}">
                                                <TextBlock Margin="0,20,0,0"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Top"
                                                           FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           Text="PREVIEW" />
                                            </Border>
                                            <Image Source="{Binding ThumbnailPath, Converter={StaticResource ThumbnailPathConverter}}"
                                                   Stretch="UniformToFill" />
                                            <Border VerticalAlignment="Bottom" Padding="9,18,9,8">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#0010141E" Offset="0" />
                                                        <GradientStop Color="#F10A0C12" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <StackPanel>
                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding FileName}"
                                                               TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                                    <Grid Margin="0,2,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                                                   Text="{Binding RecordedAtLocal, StringFormat={}{0:dd MMM · HH:mm}}" />
                                                        <TextBlock Grid.Column="1" Margin="8,0,0,0" FontSize="10"
                                                                   FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"
                                                                   Text="{Binding FileSizeDisplay}" />
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                            <Border Width="30" Height="30" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                    Background="#B20B0D12" BorderBrush="#55FFFFFF" BorderThickness="1" CornerRadius="15">
                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0,0,0"
                                                           FontSize="12" Foreground="White" Text="▶" />
                                            </Border>
                                            <Border Margin="8" Padding="7,3" HorizontalAlignment="Right" VerticalAlignment="Top"
                                                    Background="{DynamicResource AccentSoftBrush}" CornerRadius="6">
                                                <Border.Style>
                                                    <Style TargetType="{x:Type Border}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsTrimmed}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="9" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentHoverBrush}" Text="TRIMMED" />
                                            </Border>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Compatibility/latest saved state used by code and accessibility -->
                <Border x:Name="LastSavedPanel" Grid.Row="2" Panel.ZIndex="10"
                        Margin="18,72,18,64" Padding="10"
                        VerticalAlignment="Top" HorizontalAlignment="Right" Background="{StaticResource SurfaceTranslucentBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="9"
                        Visibility="Collapsed" AutomationProperties.LiveSetting="Polite">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="26" Height="26" Margin="0,0,9,0" VerticalAlignment="Center"
                                Background="{StaticResource SuccessSoftBrush}" CornerRadius="13">
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="14" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"
                                       Text="&#x2713;" />
                        </Border>
                        <TextBlock x:Name="LastSavedText" MaxWidth="330" VerticalAlignment="Center"
                                   Style="{StaticResource MutedTextStyle}" TextTrimming="CharacterEllipsis"
                                   AutomationProperties.LiveSetting="Polite" />
                        <Button x:Name="OpenLastClipButton" Margin="8,0,0,0" Height="32" MinHeight="32" Padding="10,4"
                                Content="Open" Click="OpenLastClipButton_Click" Style="{StaticResource QuietButtonStyle}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
