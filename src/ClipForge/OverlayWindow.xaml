<Window x:Class="ClipForge.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClipForge overlay"
        Width="390"
        Height="176"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        UseLayoutRounding="True"
        Opacity="0"
        Loaded="OverlayWindow_Loaded"
        MouseLeftButtonDown="OverlayWindow_MouseLeftButtonDown">
    <Window.Resources>
        <Storyboard x:Key="OverlayEnterStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0"
                             To="1"
                             Duration="0:0:0.18">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="OverlayTranslate"
                             Storyboard.TargetProperty="Y"
                             From="-12"
                             To="0"
                             Duration="0:0:0.22">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Border Margin="8"
            Padding="16"
            Background="#F2131620"
            BorderBrush="#597C6CF2"
            BorderThickness="1"
            CornerRadius="18"
            Effect="{DynamicResource OverlayShadowEffect}">
        <Border.RenderTransform>
            <TranslateTransform x:Name="OverlayTranslate" />
        </Border.RenderTransform>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Border Width="31" Height="31" Margin="0,0,10,0"
                            Background="{StaticResource AccentGradientBrush}" CornerRadius="9">
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontWeight="Bold" Foreground="White" Text="CF" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock FontSize="14" FontWeight="SemiBold" Text="ClipForge overlay" />
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="OverlayStatusDot" Width="7" Height="7" Margin="0,0,6,0"
                                     VerticalAlignment="Center" Fill="{StaticResource TextMutedBrush}" />
                            <TextBlock x:Name="OverlayStatusText" Style="{StaticResource MutedTextStyle}" Text="Replay off" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="1" Width="32" Height="32" Padding="0"
                        Content="×" Click="HideButton_Click" Style="{StaticResource QuietButtonStyle}"
                        ToolTip="Hide overlay" />
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,12,0,10">
                <TextBlock x:Name="OverlayAvailableText" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Text="No replay buffered" />
                <TextBlock x:Name="OverlayHotkeyText" Margin="0,3,0,0"
                           Style="{StaticResource MutedTextStyle}" Text="Use your save shortcut to capture the moment." />
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="OverlaySaveButton" Grid.Column="0" Height="38"
                        Content="Save clip" IsEnabled="False" Click="SaveButton_Click"
                        Style="{StaticResource PrimaryButtonStyle}" />
                <Button Grid.Column="2" Height="38" Content="Open app" Click="OpenAppButton_Click"
                        Style="{StaticResource SecondaryButtonStyle}" />
            </Grid>
        </Grid>
    </Border>
</Window>
